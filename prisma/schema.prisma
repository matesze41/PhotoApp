generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Photo {
  id               String   @id @default(cuid())
  name             String
  createdAt         DateTime @default(now())
  storageKey       String
  originalFilename String?
  mimeType         String?

  @@index([createdAt])
  @@index([name])
}